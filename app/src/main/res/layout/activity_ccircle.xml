<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".land.CcircleActivity">

    <androidx.appcompat.widget.Toolbar
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:id="@+id/toolbar"
        app:titleTextColor="@color/white"
        app:title="@string/ccircle"
        android:background="@color/myperple"
        tools:ignore="MissingConstraints" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_marginBottom="10dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

<!--            <TextView-->
<!--                android:layout_marginTop="5dp"-->
<!--                android:text="@string/parellelogram_Input"-->
<!--                android:gravity="center"-->
<!--                android:textSize="15sp"-->
<!--                android:layout_width="match_parent"-->
<!--                android:layout_height="wrap_content"/>-->
            <TextView
                android:layout_marginTop="5dp"
                android:text="@string/instraction"
                android:gravity="center"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/brickRedColor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>


            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:gravity="center_horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:weightSum="3">
                    <TextView
                        android:textAppearance="?android:attr/textAppearanceLarge"
                        android:textColor="#333"
                        android:gravity="center_horizontal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/bigaxis"
                        android:layout_weight="1"
                        android:textAlignment="center"/>
                    <EditText
                        android:textAppearance="?android:attr/textAppearanceLarge"
                        android:gravity="center_horizontal"
                        android:id="@+id/brittabash_EditText1"
                        android:background="@drawable/isr"
                        android:nextFocusDown="@+id/brittabash_EditText2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:hint="@string/feet"
                        android:layout_weight="1"
                        android:inputType="numberDecimal"
                        android:imeOptions="actionNext"
                        android:textAlignment="center"
                        android:importantForAutofill="no"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center_horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:weightSum="3">
                    <TextView
                        android:textAppearance="?android:attr/textAppearanceLarge"
                        android:textColor="#333"
                        android:gravity="center_horizontal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/smllaxis"
                        android:layout_weight="1"
                        android:textAlignment="center"/>
                    <EditText
                        android:textAppearance="?android:attr/textAppearanceLarge"
                        android:gravity="center_horizontal"
                        android:id="@+id/brittabash_EditText2"
                        android:background="@drawable/isr"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:hint="@string/feet"
                        android:layout_weight="1"
                        android:inputType="numberDecimal"
                        android:imeOptions="actionDone"
                        android:textAlignment="center"
                        android:importantForAutofill="no"/>
                </LinearLayout>


            </LinearLayout>

            <LinearLayout
                android:layout_marginTop="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">



                <LinearLayout
                    android:layout_marginTop="5dp"
                    android:gravity="right"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingRight="20dp"
                    android:orientation="horizontal">


                    <Button
                        android:id="@+id/calculateId"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:layout_marginLeft="50dp"
                        android:layout_width="150dp"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:text="@string/calculate"/>

                </LinearLayout>

            </LinearLayout>


            <LinearLayout

                android:id="@+id/resultId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_marginTop="5dp"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:textColor="@color/black"
                        android:gravity="center"
                        android:layout_width="150dp"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:text="@string/squarefeet"/>
                    <TextView
                        android:id="@+id/squareId"
                        android:textStyle="bold"
                        android:textColor="@color/myperple"
                        android:gravity="center"
                        android:layout_marginLeft="10dp"
                        android:layout_width="150dp"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:text=""/>

                </LinearLayout>
                <LinearLayout
                    android:layout_marginTop="5dp"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:textColor="@color/black"
                        android:gravity="center"
                        android:layout_width="150dp"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:text="@string/decemol"/>
                    <TextView
                        android:id="@+id/decemalId"
                        android:textStyle="bold"
                        android:textColor="@color/myperple"
                        android:gravity="center"
                        android:layout_marginLeft="10dp"
                        android:layout_width="150dp"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:text=""/>

                </LinearLayout>
                <LinearLayout
                    android:layout_marginTop="5dp"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:textColor="@color/black"
                        android:gravity="center"
                        android:layout_width="150dp"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:text="@string/katha"/>
                    <TextView
                        android:id="@+id/kathaId"
                        android:textStyle="bold"
                        android:textColor="@color/myperple"
                        android:gravity="center"
                        android:layout_marginLeft="10dp"
                        android:layout_width="150dp"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:text=""/>

                </LinearLayout>
                <LinearLayout
                    android:layout_marginTop="5dp"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:textColor="@color/black"
                        android:gravity="center"
                        android:layout_width="150dp"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:text="@string/squarelink"/>
                    <TextView
                        android:id="@+id/squarelinkId"
                        android:textStyle="bold"
                        android:textColor="@color/myperple"
                        android:gravity="center"
                        android:layout_marginLeft="10dp"
                        android:layout_width="150dp"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:text=""/>

                </LinearLayout>

                <LinearLayout
                    android:gravity="center"
                    android:layout_marginTop="10dp"
                    android:id="@+id/button_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <Button
                        android:id="@+id/resetId"
                        android:text="@string/reset"
                        android:layout_width="150dp"
                        android:layout_height="wrap_content"/>

                </LinearLayout>

            </LinearLayout>



        </LinearLayout>

    </ScrollView>


</LinearLayout>