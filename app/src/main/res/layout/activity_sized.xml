<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".timber.SizedActivity">

    <androidx.appcompat.widget.Toolbar
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:id="@+id/toolbar"
        app:titleTextColor="@color/white"
        app:title="@string/sized"
        android:background="@color/oliveDrabColor"
        tools:ignore="MissingConstraints" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_marginBottom="10dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">


            <ImageView
                android:layout_margin="10dp"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:src="@drawable/sized"/>

            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:weightSum="3">
                <TextView
                    android:textAppearance="?android:attr/textAppearanceMedium"
                    android:gravity="start"
                    android:layout_gravity="top"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/length"
                    android:layout_weight="1"/>
                <EditText
                    android:textAppearance="?android:attr/textAppearanceMedium"
                    android:gravity="center"
                    android:layout_gravity="top"
                    android:id="@+id/lengthId"
                    android:background="@drawable/isr"
                    android:nextFocusDown="@+id/et_gor_prostho"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:hint="@string/_0"
                    android:layout_weight="1"
                    android:inputType="numberDecimal"
                    android:imeOptions="actionNext"
                    android:importantForAutofill="no"/>
                <TextView
                    android:textAppearance="?android:attr/textAppearanceMedium"
                    android:gravity="start"
                    android:layout_gravity="top"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/feet"
                    android:layout_weight="0.5"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:weightSum="3">
                <TextView
                    android:textAppearance="?android:attr/textAppearanceMedium"
                    android:gravity="start"
                    android:layout_gravity="top"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/width"
                    android:layout_weight="1"/>
                <EditText
                    android:textAppearance="?android:attr/textAppearanceMedium"
                    android:gravity="center"
                    android:layout_gravity="top"
                    android:id="@+id/widthId"
                    android:background="@drawable/isr"
                    android:nextFocusDown="@+id/et_gor_uchchata"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:hint="@string/_0"
                    android:layout_weight="1"
                    android:inputType="numberDecimal"
                    android:imeOptions="actionNext"
                    android:importantForAutofill="no"/>
                <TextView
                    android:textAppearance="?android:attr/textAppearanceMedium"
                    android:gravity="start"
                    android:layout_gravity="top"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/inch"
                    android:layout_weight="0.5"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:weightSum="3">
                <TextView
                    android:textAppearance="?android:attr/textAppearanceMedium"
                    android:gravity="start"
                    android:layout_gravity="top"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/thickness"
                    android:layout_weight="1"/>
                <EditText
                    android:textAppearance="?android:attr/textAppearanceMedium"
                    android:gravity="center"
                    android:layout_gravity="top"
                    android:id="@+id/thicknessId"
                    android:background="@drawable/isr"
                    android:nextFocusDown="@+id/et_proti_ghonofoter_dam"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:hint="@string/_0"
                    android:layout_weight="1"
                    android:inputType="numberDecimal"
                    android:imeOptions="actionNext"
                    android:importantForAutofill="no"/>
                <TextView
                    android:textAppearance="?android:attr/textAppearanceMedium"
                    android:gravity="start"
                    android:layout_gravity="top"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/inch"
                    android:layout_weight="0.5"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:weightSum="3">
                <TextView
                    android:textAppearance="?android:attr/textAppearanceMedium"
                    android:gravity="start"
                    android:layout_gravity="top"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/quntity"
                    android:layout_weight="1"/>
                <EditText
                    android:textAppearance="?android:attr/textAppearanceMedium"
                    android:gravity="center"
                    android:layout_gravity="top"
                    android:id="@+id/quantityId"
                    android:background="@drawable/isr"
                    android:nextFocusDown="@+id/et_proti_ghonofoter_dam"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:hint="@string/_0"
                    android:layout_weight="1"
                    android:inputType="numberDecimal"
                    android:imeOptions="actionNext"
                    android:importantForAutofill="no"/>
                <TextView
                    android:textAppearance="?android:attr/textAppearanceMedium"
                    android:gravity="start"
                    android:layout_gravity="top"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/piece"
                    android:layout_weight="0.5"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:weightSum="3">
                <TextView
                    android:textAppearance="?android:attr/textAppearanceMedium"
                    android:gravity="start"
                    android:layout_gravity="top"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/prize"
                    android:layout_weight="1"/>
                <EditText
                    android:textAppearance="?android:attr/textAppearanceMedium"
                    android:gravity="center"
                    android:layout_gravity="top"
                    android:id="@+id/priceId"
                    android:background="@drawable/isr"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:hint="@string/_0"
                    android:layout_weight="1"
                    android:inputType="numberDecimal"
                    android:imeOptions="actionDone"
                    android:importantForAutofill="no"/>
                <TextView
                    android:textAppearance="?android:attr/textAppearanceMedium"
                    android:gravity="start"
                    android:layout_gravity="top"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/taka"
                    android:layout_weight="0.5"/>
            </LinearLayout>


            <LinearLayout
                android:layout_marginTop="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">


                <LinearLayout
                    android:layout_marginTop="5dp"
                    android:gravity="right"
                    android:layout_marginBottom="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">


                    <Button
                        android:id="@+id/calculateId"
                        android:layout_marginRight="20dp"
                        android:textColor="@color/white"
                        android:layout_width="150dp"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:backgroundTint="@color/oliveDrabColor"
                        android:text="@string/calculate"/>

                </LinearLayout>


                    <LinearLayout
                        android:visibility="gone"
                        android:id="@+id/resultId"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_marginBottom="20dp"
                            android:gravity="center"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:textColor="@color/myperple"
                                android:gravity="center"
                                android:layout_width="150dp"
                                android:layout_height="wrap_content"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:text="@string/cft"/>
                            <TextView
                                android:id="@+id/cftId"
                                android:textStyle="bold"
                                android:textColor="@color/myperple"
                                android:gravity="center"
                                android:layout_marginLeft="10dp"
                                android:layout_width="150dp"
                                android:layout_height="wrap_content"
                                android:textSize="20sp"
                                android:text=""/>


                        </LinearLayout>

                        <LinearLayout
                            android:layout_marginBottom="50dp"
                            android:layout_marginTop="5dp"
                            android:gravity="center"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:textColor="@color/black"
                                android:gravity="center"
                                android:layout_width="150dp"
                                android:layout_height="wrap_content"
                                android:textSize="15sp"
                                android:text="Price :"/>
                            <TextView
                                android:id="@+id/prizeId"
                                android:textStyle="bold"
                                android:textColor="@color/myperple"
                                android:gravity="center"
                                android:layout_marginLeft="10dp"
                                android:layout_width="150dp"
                                android:layout_height="wrap_content"
                                android:textSize="15sp"
                                android:text=""/>

                        </LinearLayout>

                        <LinearLayout
                            android:gravity="center"
                            android:layout_marginTop="10dp"
                            android:layout_marginBottom="50dp"
                            android:id="@+id/button_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <Button
                                android:visibility="visible"
                                android:id="@+id/resetId"
                                android:textColor="@color/white"
                                android:gravity="center"
                                android:layout_width="150dp"
                                android:layout_height="wrap_content"
                                android:textSize="15sp"
                                android:backgroundTint="@color/oliveDrabColor"
                                android:text="@string/reset"/>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>



    </ScrollView>

</LinearLayout>