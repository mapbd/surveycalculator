<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SoilActivity">

    <androidx.appcompat.widget.Toolbar
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:id="@+id/toolbar"
        app:titleTextColor="@color/white"
        app:title="@string/title_soil"
        android:background="@color/myperple"
        tools:ignore="MissingConstraints" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_marginBottom="10dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <ImageView
                android:layout_margin="10dp"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:src="@drawable/soil_rules"/>
            <TextView
                android:layout_marginTop="5dp"
                android:text="@string/instraction"
                android:gravity="center"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/brickRedColor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:weightSum="3">
                    <TextView
                        android:textAppearance="?android:attr/textAppearanceMedium"
                        android:gravity="start"
                        android:layout_gravity="top"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/average_length"
                        android:layout_weight="1"/>
                    <EditText
                        android:textAppearance="?android:attr/textAppearanceMedium"
                        android:gravity="center"
                        android:layout_gravity="top"
                        android:id="@+id/length4Id"
                        android:background="@drawable/isr"
                        android:nextFocusDown="@+id/et_gor_prostho"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:hint="@string/_0"
                        android:layout_weight="1"
                        android:inputType="numberDecimal"
                        android:imeOptions="actionNext"
                        android:importantForAutofill="no"/>
                    <TextView
                        android:textAppearance="?android:attr/textAppearanceMedium"
                        android:gravity="start"
                        android:layout_gravity="top"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/feet"
                        android:layout_weight="0.5"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:weightSum="3">
                    <TextView
                        android:textAppearance="?android:attr/textAppearanceMedium"
                        android:gravity="start"
                        android:layout_gravity="top"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/average_width"
                        android:layout_weight="1"/>
                    <EditText
                        android:textAppearance="?android:attr/textAppearanceMedium"
                        android:gravity="center"
                        android:layout_gravity="top"
                        android:id="@+id/length5Id"
                        android:background="@drawable/isr"
                        android:nextFocusDown="@+id/et_gor_uchchata"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:hint="@string/_0"
                        android:layout_weight="1"
                        android:inputType="numberDecimal"
                        android:imeOptions="actionNext"
                        android:importantForAutofill="no"/>
                    <TextView
                        android:textAppearance="?android:attr/textAppearanceMedium"
                        android:gravity="start"
                        android:layout_gravity="top"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/feet"
                        android:layout_weight="0.5"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:weightSum="3">
                    <TextView
                        android:textAppearance="?android:attr/textAppearanceMedium"
                        android:gravity="start"
                        android:layout_gravity="top"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/average_height"
                        android:layout_weight="1"/>
                    <EditText
                        android:textAppearance="?android:attr/textAppearanceMedium"
                        android:gravity="center"
                        android:layout_gravity="top"
                        android:id="@+id/length6Id"
                        android:background="@drawable/isr"
                        android:nextFocusDown="@+id/et_proti_ghonofoter_dam"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:hint="@string/_0"
                        android:layout_weight="1"
                        android:inputType="numberDecimal"
                        android:imeOptions="actionNext"
                        android:importantForAutofill="no"/>
                    <TextView
                        android:textAppearance="?android:attr/textAppearanceMedium"
                        android:gravity="start"
                        android:layout_gravity="top"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/feet"
                        android:layout_weight="0.5"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:weightSum="3">
                    <TextView
                        android:textAppearance="?android:attr/textAppearanceMedium"
                        android:gravity="start"
                        android:layout_gravity="top"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/prize"
                        android:layout_weight="1"/>
                    <EditText
                        android:textAppearance="?android:attr/textAppearanceMedium"
                        android:gravity="center"
                        android:layout_gravity="top"
                        android:id="@+id/length1Id"
                        android:background="@drawable/isr"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:hint="@string/_0"
                        android:layout_weight="1"
                        android:inputType="numberDecimal"
                        android:imeOptions="actionDone"
                        android:importantForAutofill="no"/>
                    <TextView
                        android:textAppearance="?android:attr/textAppearanceMedium"
                        android:gravity="start"
                        android:layout_gravity="top"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/taka"
                        android:layout_weight="0.5"/>
                </LinearLayout>

            </LinearLayout>


            <LinearLayout
                android:layout_marginTop="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_marginTop="5dp"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:visibility="invisible"
                        android:id="@+id/resetId"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:layout_width="150dp"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:text="@string/reset"/>
                    <Button
                        android:id="@+id/calculateId"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:layout_marginLeft="50dp"
                        android:layout_width="150dp"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:text="@string/calculate"/>

                </LinearLayout>

            </LinearLayout>


            <LinearLayout
                android:visibility="gone"
                android:id="@+id/resultId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_marginTop="5dp"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:textColor="@color/black"
                        android:gravity="center"
                        android:layout_width="150dp"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:text="@string/cft"/>
                    <TextView
                        android:id="@+id/squareId"
                        android:textStyle="bold"
                        android:textColor="@color/myperple"
                        android:gravity="center"
                        android:layout_marginLeft="10dp"
                        android:layout_width="150dp"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:text=""/>

                </LinearLayout>

                <LinearLayout
                    android:layout_marginBottom="50dp"
                    android:layout_marginTop="5dp"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:textColor="@color/black"
                        android:gravity="center"
                        android:layout_width="150dp"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:text="@string/price"/>
                    <TextView
                        android:id="@+id/kathaId"
                        android:textStyle="bold"
                        android:textColor="@color/myperple"
                        android:gravity="center"
                        android:layout_marginLeft="10dp"
                        android:layout_width="150dp"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:text=""/>

                </LinearLayout>


                <LinearLayout
                    android:gravity="center"
                    android:layout_marginTop="10dp"
                    android:id="@+id/button_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">


                </LinearLayout>

            </LinearLayout>



        </LinearLayout>

    </ScrollView>

</LinearLayout>